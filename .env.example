# ─── Acuity Gateway — configuration template ─────────────────────────
# Copy this file to `.env` and fill in THIS clinic's values.
#   cp .env.example .env
# The real .env is git-ignored and must NEVER be committed. One leaked
# repo with embedded credentials would compromise every clinic at once.
# Everything clinic-specific lives here, never in code (spec #23/#24).

# ── Server ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Public URL this Gateway is reachable at (used when registering the
# webhook callback with Acuity). On Lightsail this is your HTTPS domain.
PUBLIC_BASE_URL=http://localhost:3000

# ── Acuity (system of record) ───────────────────────────────────────
# From Acuity: Business Settings → Integrations → API.
ACUITY_USER_ID=
ACUITY_API_KEY=
# Base URL of the Acuity API.
#   Local dev (mock):  http://localhost:4000
#   Live:              https://acuityscheduling.com
ACUITY_API_BASE=http://localhost:4000
# Shared secret Acuity signs outbound webhooks with, so Gateway can
# verify that inbound webhook calls are genuinely from Acuity.
ACUITY_WEBHOOK_SECRET=

# ── Clinic identity (iframe + CORS perimeter) ───────────────────────
# The clinic's public website allowed to embed the booking portal.
# Drives BOTH the CORS allow-list and the CSP frame-ancestors header.
# Comma-separate if there is more than one origin.
CLINIC_ORIGIN=https://www.example-clinic.com.au
CLINIC_NAME=Example Clinic

# ── Admin dashboard (/admin) ────────────────────────────────────────
# Use a long random string. Access attempts are audit-logged.
ADMIN_PASSWORD=change-me-to-a-long-random-secret
# Optional comma-separated IP allow-list for /admin (blank = allow all).
ADMIN_IP_ALLOWLIST=
# Admin login session lifetime (ms). Default 8 hours.
ADMIN_SESSION_TTL_MS=28800000

# ── Cellcast SMS ────────────────────────────────────────────────────
# Leave CELLCAST_API_KEY blank to disable SMS (booking still works).
CELLCAST_API_KEY=
# Current generation (Bearer auth): https://api.cellcast.com
# Legacy v3 (APPKEY auth):          https://cellcast.com.au/api/v3
CELLCAST_API_BASE=https://api.cellcast.com
# Sender ID: alphanumeric (<=11 chars, ONE-WAY) or a number (for two-way replies).
CELLCAST_SENDER_ID=
# Optional HTTP Basic Auth Cellcast sends on its inbound/DLR webhooks
# (configure the same user/pass in the Cellcast dashboard webhook settings).
CELLCAST_WEBHOOK_USER=
CELLCAST_WEBHOOK_PASS=

# ── Local storage ───────────────────────────────────────────────────
# Relative path keeps Windows-dev and Linux-prod identical (spec #3).
DB_PATH=./data/gateway.sqlite

# ── Availability cache ──────────────────────────────────────────────
# How many days forward to cache open slots, and how often to refresh.
AVAILABILITY_WINDOW_DAYS=60
AVAILABILITY_REFRESH_MS=300000

# ── Retention / purge (APP 11, spec #19–#22) ────────────────────────
# Post-appointment backstop window before confirmed-synced PII is purged.
PII_BACKSTOP_DAYS=7
# Local hour (0-23) the nightly purge runs at/after.
PURGE_HOUR=3
# SMS log rows older than this many days are trimmed by the purge job.
SMS_RETENTION_DAYS=30

# ── Deployment (used by setup.sh on Lightsail) ──────────────────────
# Public domain that points at this Lightsail instance (for nginx + SSL).
DOMAIN=
# Email for Let's Encrypt certificate registration/renewal notices.
LETSENCRYPT_EMAIL=
